@model CMS.Data.Entities.Customer

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm khách hàng";
}

<div class="card-premium">
    <div class="mb-4">
        <h1 class="h3 mb-1 fw-bold"><i class="bi bi-person-plus text-muted"></i> Thêm Khách hàng mới</h1>
        <p class="text-muted small">Nhập đầy đủ thông tin để khởi tạo tài khoản khách hàng mới.</p>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <form asp-action="Create" method="post">
                <div class="mb-4">
                    <label asp-for="FullName" class="form-label">Họ và tên</label>
                    <input asp-for="FullName" class="form-control" placeholder="Ví dụ: Nguyễn Văn A" required />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label">Địa chỉ Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="example@gmail.com" required />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Phone" class="form-label">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control" placeholder="Ví dụ: 0987654321" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Address" class="form-label">Địa chỉ thường trú</label>
                    <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ của khách hàng..." />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label">Mật khẩu đăng nhập</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu tài khoản" required />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mt-4 pt-2">
                    <button type="submit" class="btn btn-premium-primary border-0 me-2">Lưu khách hàng</button>
                    <a asp-action="Index" class="btn btn-premium-outline text-decoration-none">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
