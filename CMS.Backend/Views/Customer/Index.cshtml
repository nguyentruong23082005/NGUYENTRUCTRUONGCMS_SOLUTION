@model IEnumerable<CMS.Data.Entities.Customer>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Khách hàng";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold"><i class="bi bi-person-badge-fill text-muted"></i> Danh sách Khách hàng</h1>
        <a asp-action="Create" class="btn-premium-primary text-decoration-none">
            <i class="bi bi-plus-lg"></i> Thêm khách hàng
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 mb-4" role="alert" style="background-color: #f0fdf4; color: #166534;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-alert="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 mb-4" role="alert" style="background-color: #fef2f2; color: #991b1b;">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-alert="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table-premium">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Họ tên</th>
                    <th scope="col">Email</th>
                    <th scope="col">Số điện thoại</th>
                    <th scope="col">Địa chỉ</th>
                    <th scope="col" width="160">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-semibold text-black">@item.FullName</td>
                        <td>@item.Email</td>
                        <td class="text-muted">@(item.Phone ?? "Chưa có")</td>
                        <td class="text-muted">@(item.Address ?? "Chưa có")</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" 
                                   class="btn btn-sm btn-warning" 
                                   aria-label="Sửa thông tin khách hàng @item.FullName">Sửa</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" 
                                      onsubmit="return confirm('Bạn có chắc chắn muốn xóa khách hàng này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger" 
                                            aria-label="Xóa khách hàng @item.FullName">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
