@model CMS.Backend.Models.PaginatedList<CMS.Data.Entities.CustomerAddress>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Địa chỉ khách hàng";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold">
            <span class="material-symbols-rounded align-middle text-muted" aria-hidden="true">location_on</span>
            Danh sách Địa chỉ khách hàng
        </h1>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Trash" class="btn btn-premium-outline text-decoration-none">
            <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">delete</span>
            Thùng rác
            </a>
            <a asp-action="Create" class="btn-premium-primary text-decoration-none">
            <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">add</span>
            Thêm địa chỉ
        </a>
            </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 mb-4" role="alert" style="background-color: #f0fdf4; color: #166534;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 mb-4" role="alert" style="background-color: #fef2f2; color: #991b1b;">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table-premium">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Khách hàng</th>
                    <th scope="col">Người nhận</th>
                    <th scope="col">Điện thoại</th>
                    <th scope="col">Địa chỉ</th>
                    <th scope="col">Mặc định</th>
                    <th scope="col" width="130">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-semibold text-black">@(item.Customer?.FullName ?? "Không rõ")</td>
                        <td class="text-muted">@item.ReceiverName</td>
                        <td class="text-muted">@item.ReceiverPhone</td>
                        <td class="text-muted">@item.AddressLine, @item.Ward, @item.District, @item.Province</td>
                        <td>
                            @if (item.IsDefault)
                            {
                                <span class="badge bg-success rounded-pill px-2.5 py-1">
                                    <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">check_circle</span>
                                    Mặc định
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2 flex-nowrap">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-info text-white d-inline-flex align-items-center justify-content-center"
                                   title="Xem chi tiết"
                                   aria-label="Xem chi tiết địa chỉ @item.Id">
                                    <span class="material-symbols-rounded admin-icon-sm" aria-hidden="true">visibility</span>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning d-inline-flex align-items-center justify-content-center"
                                   title="Sửa địa chỉ"
                                   aria-label="Sửa địa chỉ @item.Id">
                                    <span class="material-symbols-rounded admin-icon-sm" aria-hidden="true">edit_square</span>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                      onsubmit="return confirm('Chuyển địa chỉ này vào thùng rác?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm btn-danger d-inline-flex align-items-center justify-content-center"
                                            title="Xóa địa chỉ"
                                            aria-label="Xóa địa chỉ @item.Id">
                                        <span class="material-symbols-rounded admin-icon-sm" aria-hidden="true">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="Model" />
</div>
