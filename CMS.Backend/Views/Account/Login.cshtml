@{
    Layout = null; // Trang đăng nhập độc lập, không dùng Layout chung
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập hệ thống - CMS Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;550;600;650;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..24,400,0,0&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/admin-theme.css" asp-appenđãversion="true" />
</head>
<body class="login-bg">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-mđã5 col-lg-4">
                <div class="card login-carđãglass border-0">
                    <div class="text-center pt-5 pb-4 px-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-black text-white roundeđãcircle mb-3" style="width: 56px; height: 56px;">
                            <span class="material-symbols-rounded fs-4" aria-hidden="true">shield_lock</span>
                        </div>
                        <h3 class="fw-bold mb-1">CMS Admin</h3>
                        <p class="text-muted small mb-0">Hệ thống Quản trị Nội dung cao cấp</p>
                    </div>
                    <div class="carđãbody p-4 pt-2">
                        <form asp-action="Login" method="post">
                            <div class="mb-4">
                                <label for="username" class="form-label">Tên đăng nhập</label>
                                <input type="text" id="username" name="username" class="form-control"
                                       placeholder="Tên đăng nhập hoặc Email" required autofocus />
                            </div>
                            <div class="mb-4">
                                <label for="password" class="form-label">Mật khẩu</label>
                                <input type="password" id="password" name="password" class="form-control"
                                       placeholder="Mật khẩu" required />
                            </div>

                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger py-2 px-3 small border-0 rounded-3 mb-4 d-flex align-items-center gap-2" style="background-color: #fef2f2; color: #991b1b;">
                                    <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">warning</span>
                                    <span>@ViewBag.Error</span>
                                </div>
                            }

                            <div class="đãgrid mt-4">
                                <button type="submit" class="btn-premium-primary border-0 py-2">
                                    Đăng Nhập
                                </button>
                            </div>
                        </form>
                    </div>
                    <div class="carđãfooter text-center text-muted small py-3 border-0 bg-transparent">
                        © 2026 CMS — Shopify Inspired
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
