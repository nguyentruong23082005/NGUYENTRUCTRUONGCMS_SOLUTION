@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Không có quyền truy cập";
}

<div class="card-premium text-center mx-auto" style="max-width: 720px;">
    <div class="py-4">
        <div class="mb-3">
            <span class="material-symbols-rounded text-danger" aria-hidden="true" style="font-size: 72px;">block</span>
        </div>
        <p class="text-uppercase fw-bold text-danger small mb-2">Mã lỗi 403</p>
        <h1 class="h3 fw-bold mb-3">Không có quyền truy cập</h1>
        <p class="text-muted mb-4">
            Bạn không có đủ quyền hạn để xem trang này.<br />
            Vui lòng liên hệ quản trị viên để được cấp quyền phù hợp.
        </p>
        <div class="d-flex justify-content-center gap-2 flex-wrap">
            <a href="/" class="btn btn-premium-primary border-0 text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">home</span>
                Quay lại trang chủ
            </a>
            <a asp-controller="Account" asp-action="Logout" class="btn btn-premium-outline text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">logout</span>
                Đăng xuất
            </a>
        </div>
    </div>
</div>
