@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Không có quyền truy cập";
}

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-body py-5">
                    <h1 class="display-1 text-danger fw-bold">403</h1>
                    <h3 class="text-danger mb-3">KHÔNG CÓ QUYỀN TRUY CẬP</h3>
                    <p class="text-muted mb-4">
                        Bạn không có đủ quyền hạn để xem trang này.<br />
                        Vui lòng liên hệ quản trị viên để được cấp quyền.
                    </p>
                    <div class="d-flex justify-content-center gap-2">
                        <a href="/" class="btn btn-primary">
                            <i class="bi bi-house-fill"></i> Quay lại trang chủ
                        </a>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-secondary">
                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
