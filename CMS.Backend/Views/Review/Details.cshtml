@model CMS.Data.Entities.Review

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết đánh giá";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold">
            <span class="material-symbols-rounded align-middle text-muted" aria-hidden="true">reviews</span>
            Chi tiết đánh giá #@Model.Id
        </h1>
        <a asp-action="Index" class="btn btn-premium-outline text-decoration-none">
            <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">arrow_back</span>
            Quay lại
        </a>
    </div>

    <dl class="row mb-0">
        <dt class="col-sm-3 text-muted">Sản phẩm</dt>
        <dd class="col-sm-9 fw-semibold">@(Model.Product?.Name ?? "—")</dd>

        <dt class="col-sm-3 text-muted">Khách hàng</dt>
        <dd class="col-sm-9">@(Model.Customer?.FullName ?? "—")</dd>

        <dt class="col-sm-3 text-muted">Rating</dt>
        <dd class="col-sm-9 text-warning">
            @for (var i = 0; i < Model.Rating; i++)
            {
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">star</span>
            }
        </dd>

        <dt class="col-sm-3 text-muted">Bình luận</dt>
        <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Comment) ? "—" : Model.Comment)</dd>

        <dt class="col-sm-3 text-muted">Ngày tạo</dt>
        <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
    </dl>
</div>
