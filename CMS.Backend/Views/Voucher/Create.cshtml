@model CMS.Data.Entities.Voucher
@{ Layout = "_LayoutAdmin"; ViewData["Title"] = "Thêm voucher"; }
<div class="card-premium">
    <h1 class="h3 mb-4 fw-bold"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">new_label</span> Thêm voucher</h1>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="Code" class="form-label fw-semibold">Mã voucher</label><input asp-for="Code" class="form-control text-uppercase" /><span asp-validation-for="Code" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="DiscountValue" class="form-label fw-semibold">Giá trị giảm</label><input asp-for="DiscountValue" class="form-control" /><span asp-validation-for="DiscountValue" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="MinimumOrderAmount" class="form-label fw-semibold">Đơn tối thiểu</label><input asp-for="MinimumOrderAmount" class="form-control" /><span asp-validation-for="MinimumOrderAmount" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="ExpiryDate" class="form-label fw-semibold">Ngày hết hạn</label><input asp-for="ExpiryDate" type="date" class="form-control" /></div>
            <div class="col-md-6 form-check mt-4 ms-2"><input asp-for="IsPercent" class="form-check-input" /><label asp-for="IsPercent" class="form-check-label">Giảm theo phần trăm</label></div>
            <div class="col-md-6 form-check mt-4 ms-2"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">Đang hoạt động</label></div>
        </div>
        <div class="d-flex gap-2 mt-4"><button type="submit" class="btn btn-premium-primary border-0 me-2"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">save</span> Lưu</button><a asp-action="Index" class="btn btn-premium-outline text-decoration-none"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">arrow_back</span> Hủy</a></div>
    </form>
</div>
