@model CMS.Data.Entities.OptionValue

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết giá trị tùy chọn";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold">
            <span class="material-symbols-rounded align-middle text-muted" aria-hidden="true">checklist</span>
            @Model.Name
        </h1>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-premium-primary border-0 text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">edit_square</span>
                Sửa
            </a>
            <a asp-action="Index" class="btn btn-premium-outline text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">arrow_back</span>
                Quay lại
            </a>
        </div>
    </div>

    <dl class="row mb-0">
        <dt class="col-sm-3 text-muted">Nhóm tùy chọn</dt>
        <dd class="col-sm-9 fw-semibold">@(Model.OptionGroup?.Name ?? "—")</dd>

        <dt class="col-sm-3 text-muted">Tên giá trị</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3 text-muted">Phụ thu</dt>
        <dd class="col-sm-9">@Model.PriceSurcharge.ToString("N0") d</dd>

        <dt class="col-sm-3 text-muted">Trạng thái</dt>
        <dd class="col-sm-9">
            <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary") rounded-pill px-2.5 py-1">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">@(Model.IsActive ? "check_circle" : "remove_circle")</span>
                @(Model.IsActive ? "Đang bật" : "Đã tắt")
            </span>
        </dd>

        <dt class="col-sm-3 text-muted">Tồn kho</dt>
        <dd class="col-sm-9">@(Model.StockQuantity?.ToString() ?? "Không giới hạn")</dd>
    </dl>
</div>
