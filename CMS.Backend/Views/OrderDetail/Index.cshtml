@model CMS.Backend.Models.PaginatedList<CMS.Data.Entities.OrderDetail>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold"><span class="material-symbols-rounded align-middle text-muted" aria-hidden="true">checklist</span> Tất cả Chi tiết Đơn hàng</h1>
            <p class="text-muted small mb-0">Xem chi tiết theo từng đơn: <a asp-controller="Order" asp-action="Index">vào Đơn hàng > <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">visibility</span> Xem</a></p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 mb-4" role="alert" style="background-color: #f0fdf4; color: #166534;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table-premium">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Mã đơn</th>
                    <th scope="col">Sản phẩm</th>
                    <th scope="col" class="text-center">Số lượng</th>
                    <th scope="col" class="text-end">Đơn giá</th>
                    <th scope="col" class="text-end">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    var total = item.Quantity * item.UnitPrice;
                    <tr>
                        <td>@item.Id</td>
                        <td>
                            <a asp-controller="Order" asp-action="Details" asp-route-id="@item.OrderId"
                               class="fw-semibold text-decoration-none">#@item.OrderId</a>
                        </td>
                        <td>@(item.Product?.Name ?? "Không rõ")</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@item.UnitPrice.ToString("N0") d</td>
                        <td class="text-end fw-bold text-danger">@total.ToString("N0") d</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="Model" />
</div>
