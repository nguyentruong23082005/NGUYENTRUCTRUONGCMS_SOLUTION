@model CMS.Data.Entities.OrderDetail

@{
    
    Layout = "_LayoutAdmin";ViewData["Title"] = "Sửa chi tiết đơn hàng";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="text-warning mb-4">✏️ Chỉnh Sửa Chi Tiết Đơn Hàng</h2>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="OrderId" class="form-label fw-bold">Mã đơn hàng</label>
            <select asp-for="OrderId" class="form-select" asp-items="ViewBag.OrderId" required>
                <option value="">-- Chọn đơn hàng --</option>
            </select>
            <span asp-validation-for="OrderId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ProductId" class="form-label fw-bold">Sản phẩm</label>
            <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId" required>
                <option value="">-- Chọn sản phẩm --</option>
            </select>
            <span asp-validation-for="ProductId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Quantity" class="form-label fw-bold">Số lượng</label>
            <input asp-for="Quantity" type="number" class="form-control" min="1" required />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="UnitPrice" class="form-label fw-bold">Đơn giá</label>
            <input asp-for="UnitPrice" type="number" step="0.01" class="form-control" required />
            <span asp-validation-for="UnitPrice" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning">Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
