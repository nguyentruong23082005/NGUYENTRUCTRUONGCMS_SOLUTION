@model CMS.Data.Entities.OrderDetail

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa chi tiết đơn hàng";
}

<div class="card-premium">
    <div class="mb-4">
        <h1 class="h3 mb-1 fw-bold"><i class="bi bi-list-check text-muted"></i> Chỉnh sửa Chi tiết Đơn hàng</h1>
        <p class="text-muted small">Cập nhật thông tin về sản phẩm và số lượng trong chi tiết đơn hàng.</p>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-4">
                    <label asp-for="OrderId" class="form-label">Mã đơn hàng</label>
                    <select asp-for="OrderId" class="form-select" asp-items="ViewBag.OrderId" required>
                        <option value="">Chọn đơn hàng</option>
                    </select>
                    <span asp-validation-for="OrderId" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ProductId" class="form-label">Sản phẩm</label>
                    <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId" required>
                        <option value="">Chọn sản phẩm</option>
                    </select>
                    <span asp-validation-for="ProductId" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Quantity" class="form-label">Số lượng</label>
                    <input asp-for="Quantity" type="number" class="form-control" min="1" placeholder="Số lượng sản phẩm" required />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="UnitPrice" class="form-label">Đơn giá (VNĐ)</label>
                    <input asp-for="UnitPrice" type="number" step="1" class="form-control" placeholder="Đơn giá sản phẩm" required />
                    <span asp-validation-for="UnitPrice" class="text-danger small"></span>
                </div>

                <div class="mt-4 pt-2">
                    <button type="submit" class="btn btn-premium-primary border-0 me-2">Lưu thay đổi</button>
                    <a asp-action="Index" class="btn btn-premium-outline text-decoration-none">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
