@{
    ViewData["Title"] = "Chính sách bảo mật";
}

<div class="card-premium mx-auto" style="max-width: 820px;">
    <div class="d-flex align-items-start gap-3 mb-4">
        <span class="material-symbols-rounded text-muted" aria-hidden="true" style="font-size: 48px;">privacy_tip</span>
        <div>
            <p class="text-uppercase fw-bold text-muted small mb-2">Privacy Policy</p>
            <h1 class="h3 fw-bold mb-2">Chính sách bảo mật</h1>
