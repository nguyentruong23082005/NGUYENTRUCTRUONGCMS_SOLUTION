@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-speedometer2"></i> BẢNG ĐIỀU KHIỂN</h2>
    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card bg-primary text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase">Bài viết</h6>
                            <h2 class="mb-0">@ViewBag.PostCount</h2>
                        </div>
                        <i class="bi bi-file-earmark-post" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top-0">
                    <a asp-controller="Post" asp-action="Index" class="text-white text-decoration-none small">Xem chi tiết <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card bg-success text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase">Danh mục</h6>
                            <h2 class="mb-0">@ViewBag.CategoryCount</h2>
                        </div>
                        <i class="bi bi-folder" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top-0">
                    <a asp-controller="Category" asp-action="Index" class="text-white text-decoration-none small">Xem chi tiết <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card bg-warning text-dark shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase">Thành viên</h6>
                            <h2 class="mb-0">@ViewBag.UserCount</h2>
                        </div>
                        <i class="bi bi-people" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top-0">
                    <a asp-controller="User" asp-action="Index" class="text-dark text-decoration-none small">Xem chi tiết <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card bg-info text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase">Sản phẩm</h6>
                            <h2 class="mb-0">@ViewBag.ProductCount</h2>
                        </div>
                        <i class="bi bi-box-seam" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top-0">
                    <a asp-controller="Product" asp-action="Index" class="text-white text-decoration-none small">Xem chi tiết <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card bg-danger text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase">Khách hàng</h6>
                            <h2 class="mb-0">@ViewBag.CustomerCount</h2>
                        </div>
                        <i class="bi bi-person-lines-fill" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top-0">
                    <a asp-controller="Customer" asp-action="Index" class="text-white text-decoration-none small">Xem chi tiết <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card bg-secondary text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase">Đơn hàng</h6>
                            <h2 class="mb-0">@ViewBag.OrderCount</h2>
                        </div>
                        <i class="bi bi-cart3" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top-0">
                    <a asp-controller="Order" asp-action="Index" class="text-white text-decoration-none small">Xem chi tiết <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>
