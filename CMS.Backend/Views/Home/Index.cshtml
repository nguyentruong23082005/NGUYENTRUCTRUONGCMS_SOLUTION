@model List<CMS.Data.Entities.Post>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-5">
    <h2 class="mb-4 text-danger fw-bold text-center">📰 TIN TỨC MỚI NHẤT</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center">Chưa có bài viết nào. Hãy thêm bài viết mới!</div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title"
                                 style="height: 200px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-secondary text-white d-flex align-items-center justify-content-center"
                                 style="height: 200px;">
                                <span>Không có ảnh</span>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-primary mb-2" style="width: fit-content;">
                                @(item.Category?.Name ?? "Chưa phân loại")
                            </span>
                            <h5 class="card-title">@item.Title</h5>
                            <p class="card-text text-muted small">
                                @item.CreatedDate.ToString("dd/MM/yyyy")
                            </p>
                            <a asp-controller="Post" asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-outline-danger btn-sm mt-auto">
                                Đọc tiếp →
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-2">
            <a asp-controller="Post" asp-action="Index" class="btn btn-outline-secondary">
                Xem tất cả bài viết
            </a>
        </div>
    }
</div>
