@model CMS.Data.Entities.CategoryProduct

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa danh mục sản phẩm";
}

<div class="card-premium">
    <div class="mb-4">
        <h1 class="h3 mb-1 fw-bold"><i class="bi bi-grid-check text-muted"></i> Chỉnh sửa Danh mục Sản phẩm</h1>
        <p class="text-muted small">Cập nhật thông tin chi tiết của danh mục sản phẩm.</p>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-4">
                    <label asp-for="Name" class="form-label">Tên danh mục</label>
                    <input asp-for="Name" class="form-control" placeholder="Tên danh mục sản phẩm" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả danh mục..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="mt-4 pt-2">
                    <button type="submit" class="btn btn-premium-primary border-0 me-2">Lưu thay đổi</button>
                    <a asp-action="Index" class="btn btn-premium-outline text-decoration-none">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
