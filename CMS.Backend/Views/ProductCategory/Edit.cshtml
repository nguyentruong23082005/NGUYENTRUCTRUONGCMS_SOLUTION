@model CMS.Data.Entities.ProductCategory

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa danh mục sản phẩm";
}

<div class="card-premium">
    <div class="mb-4">
        <h1 class="h3 mb-1 fw-bold"><span class="material-symbols-rounded align-middle text-muted" aria-hidden="true">edit_square</span> Chỉnh sửa Danh mục Sản phẩm</h1>
        <p class="text-muted small">Cập nhật thông tin chi tiết của danh mục sản phẩm.</p>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />

                <div class="mb-4">
                    <label asp-for="Name" class="form-label fw-semibold">Tên danh mục</label>
                    <input asp-for="Name" class="form-control" placeholder="Tên danh mục sản phẩm" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ParentId" class="form-label fw-semibold">Danh mục cha</label>
                    <select asp-for="ParentId" asp-items="ViewBag.ParentCategoryList" class="form-select">
                        <option value=""> Chọn danh mục cha (nếu có) </option>
                    </select>
                    <span asp-validation-for="ParentId" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold d-block">Ảnh danh mục hiện tại</label>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-2">
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="rounded border" style="width: 120px; height: 120px; object-fit: cover;" />
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small">Chưa có ảnh</p>
                    }
                    <input type="file" name="uploadImage" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    <p class="text-muted small mt-1">Chọn ảnh khác để thay đổi. Định dạng hỗ trợ: .jpg, .jpeg, .png, .webp. Dung lượng tối đa: 2MB.</p>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-semibold">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả danh mục..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="mt-4 pt-2">
                    <button type="submit" class="btn btn-premium-primary border-0 me-2"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">save</span> Lưu thay đổi</button>
                    <a asp-action="Index" class="btn btn-premium-outline text-decoration-none"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">arrow_back</span> Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
