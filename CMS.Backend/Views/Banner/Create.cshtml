@model CMS.Data.Entities.Banner

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm banner";
}

<div class="card-premium">
    <h1 class="h3 mb-4 fw-bold">
        <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">add_photo_alternate</span>
        Thêm banner
    </h1>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Title" class="form-label fw-semibold">Tên banner</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Position" class="form-label fw-semibold">Vị trí</label>
                <input asp-for="Position" class="form-control" />
                <span asp-validation-for="Position" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="SortOrder" class="form-label fw-semibold">Thứ tự</label>
                <input asp-for="SortOrder" type="number" min="0" class="form-control" />
                <span asp-validation-for="SortOrder" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="ImageUrl" class="form-label fw-semibold">Image URL</label>
                <input asp-for="ImageUrl" class="form-control" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="LinkUrl" class="form-label fw-semibold">Link khi bấm banner</label>
                <input asp-for="LinkUrl" class="form-control" />
                <span asp-validation-for="LinkUrl" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="StartsAt" class="form-label fw-semibold">Bắt đầu hiển thị</label>
                <input asp-for="StartsAt" type="datetime-local" class="form-control" />
                <span asp-validation-for="StartsAt" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="EndsAt" class="form-label fw-semibold">Kết thúc hiển thị</label>
                <input asp-for="EndsAt" type="datetime-local" class="form-control" />
                <span asp-validation-for="EndsAt" class="text-danger"></span>
            </div>
            <div class="col-12">
                <div class="form-check form-switch">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label fw-semibold">Đang bật</label>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-premium-primary border-0 me-2">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">save</span>
                Lưu
            </button>
            <a asp-action="Index" class="btn btn-premium-outline text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">arrow_back</span>
                Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
