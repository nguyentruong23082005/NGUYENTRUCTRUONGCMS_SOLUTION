@model CMS.Backend.Models.PaginatedList<CMS.Data.Entities.Banner>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Banner";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold">
            <span class="material-symbols-rounded align-middle text-muted" aria-hidden="true">view_carousel</span>
            Quản lý Banner
        </h1>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Trash" class="btn btn-premium-outline text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">delete</span>
                Thùng rác
            </a>
            <a asp-action="Create" class="btn-premium-primary text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">add_photo_alternate</span>
                Thêm banner
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 mb-4" role="alert" style="background-color: #f0fdf4; color: #166534;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 mb-4" role="alert" style="background-color: #fef2f2; color: #991b1b;">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table-premium">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Ảnh</th>
                    <th scope="col">Tên banner</th>
                    <th scope="col">Vị trí</th>
                    <th scope="col">Thứ tự</th>
                    <th scope="col">Trạng thái</th>
                    <th scope="col" width="130">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>
                            <img src="@item.ImageUrl" alt="@item.Title" style="width: 120px; height: 48px; object-fit: cover; border-radius: 10px;" />
                        </td>
                        <td>
                            <div class="fw-semibold text-black">@item.Title</div>
                            @if (!string.IsNullOrWhiteSpace(item.LinkUrl))
                            {
                                <div class="small text-muted text-truncate" style="max-width: 260px;">@item.LinkUrl</div>
                            }
                        </td>
                        <td><span class="badge bg-light text-dark">@item.Position</span></td>
                        <td class="text-muted">@item.SortOrder</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">Đang bật</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Đang tắt</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2 flex-nowrap">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-info text-white d-inline-flex align-items-center justify-content-center"
                                   title="Xem chi tiết"
                                   aria-label="Xem chi tiết banner @item.Title">
                                    <span class="material-symbols-rounded admin-icon-sm" aria-hidden="true">visibility</span>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning d-inline-flex align-items-center justify-content-center"
                                   title="Sửa banner"
                                   aria-label="Sửa banner @item.Title">
                                    <span class="material-symbols-rounded admin-icon-sm" aria-hidden="true">edit_square</span>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                      onsubmit="return confirm('Chuyển banner này vào thùng rác?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm btn-danger d-inline-flex align-items-center justify-content-center"
                                            title="Xóa banner"
                                            aria-label="Xóa banner @item.Title">
                                        <span class="material-symbols-rounded admin-icon-sm" aria-hidden="true">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="Model" />
</div>
