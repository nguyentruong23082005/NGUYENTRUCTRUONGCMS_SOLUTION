@model CMS.Data.Entities.Order

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm đơn hàng";
}

<div class="card-premium">
    <div class="mb-4">
        <h1 class="h3 mb-1 fw-bold"><i class="bi bi-cart-plus text-muted"></i> Thêm Đơn hàng mới</h1>
        <p class="text-muted small">Khởi tạo đơn hàng mới cho khách hàng trong hệ thống.</p>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <form asp-action="Create" method="post">
                <div class="mb-4">
                    <label asp-for="CustomerId" class="form-label">Khách hàng</label>
                    <select asp-for="CustomerId" class="form-select" asp-items="ViewBag.CustomerId" required>
                        <option value="">Chọn khách hàng</option>
                    </select>
                    <span asp-validation-for="CustomerId" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="OrderDate" class="form-label">Ngày đặt hàng</label>
                    <input asp-for="OrderDate" type="datetime-local" class="form-control" />
                    <span asp-validation-for="OrderDate" class="text-danger small"></span>
                    <small class="text-muted d-block mt-1">Để trống nếu muốn tự động lấy giờ hiện tại.</small>
                </div>

                <div class="mb-4">
                    <label asp-for="Status" class="form-label">Trạng thái giao dịch</label>
                    <select asp-for="Status" class="form-select">
                        <option value="0">Chờ duyệt</option>
                        <option value="1">Đang giao</option>
                        <option value="2">Đã xong</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Notes" class="form-label">Ghi chú đơn hàng</label>
                    <textarea asp-for="Notes" class="form-control" rows="4" placeholder="Nhập ghi chú hoặc yêu cầu giao hàng..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger small"></span>
                </div>

                <div class="mt-4 pt-2">
                    <button type="submit" class="btn btn-premium-primary border-0 me-2">Lưu đơn hàng</button>
                    <a asp-action="Index" class="btn btn-premium-outline text-decoration-none">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
