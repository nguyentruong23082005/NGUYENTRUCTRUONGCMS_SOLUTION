@model IEnumerable<CMS.Data.Entities.Order>

@{
    ViewData["Title"] = "Đơn hàng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">📦 Danh Sách Đơn Hàng</h2>
        <a asp-action="Create" class="btn btn-success">+ Thêm đơn hàng</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-bordered table-striped shadow-sm align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Ngày đặt</th>
                <th>Khách hàng</th>
                <th>Trạng thái</th>
                <th>Ghi chú</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@(item.Customer?.FullName ?? "Không rõ")</td>
                    <td>
                        @switch (item.Status)
                        {
                            case 0:
                                <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                break;
                            case 1:
                                <span class="badge bg-info text-dark">Đang giao</span>
                                break;
                            case 2:
                                <span class="badge bg-success">Đã xong</span>
                                break;
                            default:
                                <span class="badge bg-secondary">Không rõ</span>
                                break;
                        }
                    </td>
                    <td>@(item.Notes ?? "Không có")</td>
                    <td>
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
