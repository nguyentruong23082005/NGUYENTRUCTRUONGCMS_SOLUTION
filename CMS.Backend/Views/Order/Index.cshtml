@using CMS.Backend.Helpers
@using CMS.Data.Entities
@model CMS.Backend.Models.OrderIndexViewModel

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Đơn hàng";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold"><span class="material-symbols-rounded align-middle text-muted" aria-hidden="true">shopping_cart</span> Danh sách Đơn hàng</h1>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Trash" class="btn btn-premium-outline text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">delete</span>
                Thùng rác
            </a>
            <a asp-action="Create" class="btn-premium-primary text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">add</span> Thêm đơn hàng
            </a>
        </div>
    </div>

    <!-- Bộ lọc & Tìm kiếm -->
    <form method="get" asp-action="Index" class="filter-section mb-4">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label fw-semibold text-muted small">Tìm kiếm</label>
                <input type="text" name="Search" value="@Model.Filter.Search" class="form-control" placeholder="ID, tên khách, SĐT..." />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold text-muted small">Trạng thái</label>
                <select name="Status" class="form-select">
                    <option value="">Tất cả trạng thái</option>
                    @foreach (OrderStatus status in Enum.GetValues(typeof(OrderStatus)))
                    {
                        var isSelected = Model.Filter.Status == status ? "selected" : null;
                        if (isSelected != null)
                        {
                            <option value="@status" selected="selected">@OrderStatusHelper.GetDisplayName(status)</option>
                        }
                        else
                        {
                            <option value="@status">@OrderStatusHelper.GetDisplayName(status)</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold text-muted small">Từ ngày</label>
                <input type="date" name="StartDate" value="@Model.Filter.StartDate?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold text-muted small">Đến ngày</label>
                <input type="date" name="EndDate" value="@Model.Filter.EndDate?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn-search-premium flex-grow-1">
                    <span class="material-symbols-rounded align-middle">search</span> Tìm kiếm
                </button>
                <a asp-action="Index" class="btn-reset-premium" title="Xóa bộ lọc">
                    <span class="material-symbols-rounded align-middle">restart_alt</span>
                </a>
            </div>
        </div>
    </form>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 mb-4" role="alert" style="background-color: #f0fdf4; color: #166534;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 mb-4" role="alert" style="background-color: #fef2f2; color: #991b1b;">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table-premium">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Ngày đặt</th>
                    <th scope="col">Khách hàng</th>
                    <th scope="col">Thanh toán</th>
                    <th scope="col">Trạng thái</th>
                    <th scope="col">Ghi chú</th>
                    <th scope="col" width="130">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Orders.Items.Any())
                {
                    @foreach (var item in Model.Orders.Items)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="text-muted text-nowrap">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="fw-semibold text-black text-nowrap">@(item.Customer?.FullName ?? "Không rõ")</td>
                            <td class="text-nowrap">
                                <div class="d-flex flex-column gap-1">
                                    <span class="small fw-semibold d-inline-flex align-items-center gap-1 text-secondary" style="font-size: 11.5px;">
                                        <span class="material-symbols-rounded align-middle" style="font-size: 14px;">payments</span>
                                        @(item.PaymentMethod == PaymentMethod.COD ? "COD" : 
                                          item.PaymentMethod == PaymentMethod.VNPay ? "VNPay" : 
                                          item.PaymentMethod == PaymentMethod.MoMo ? "MoMo" : 
                                          item.PaymentMethod == PaymentMethod.ZaloPay ? "ZaloPay" : item.PaymentMethod.ToString())
                                    </span>
                                    <span class="badge @(item.PaymentStatus == PaymentStatus.Paid ? "badge-payment-paid" : item.PaymentStatus == PaymentStatus.Failed ? "badge-payment-failed" : "badge-payment-pending") align-self-start" style="font-size: 10px; padding: 2px 6px;">
                                        @(item.PaymentStatus == PaymentStatus.Paid ? "Đã thanh toán" : 
                                          item.PaymentStatus == PaymentStatus.Failed ? "Thất bại" : "Chờ TT")
                                    </span>
                                </div>
                            </td>
                            <td class="text-nowrap">
                                <span class="badge @OrderStatusHelper.GetBadgeClass(item.Status) rounded-pill px-2.5 py-1">
                                    <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">@OrderStatusHelper.GetMaterialIcon(item.Status)</span>
                                    @OrderStatusHelper.GetDisplayName(item.Status)
                                </span>
                            </td>
                            <td class="text-muted">@(item.Notes ?? "Không có")</td>
                            <td class="text-nowrap">
                                <div class="d-flex gap-2 flex-nowrap">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-info text-white d-inline-flex align-items-center justify-content-center"
                                       title="Xem chi tiết"
                                       aria-label="Xem chi tiết đơn hàng mã số @item.Id">
                                        <span class="material-symbols-rounded admin-icon-sm" aria-hidden="true">visibility</span>
                                    </a>
                                    @{
                                        var nextStatuses = OrderStatusHelper.GetNextStatuses(item.Status)
                                            .Where(s => s != OrderStatus.Cancelled).ToList();
                                    }
                                    @if (nextStatuses.Any())
                                    {
                                        var nextLabel = OrderStatusHelper.GetNextActionLabel(item.Status);
                                        var nextIcon = OrderStatusHelper.GetNextActionIcon(item.Status);
                                        <form asp-action="AdvanceStatus" asp-route-id="@item.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-sm btn-warning d-inline-flex align-items-center justify-content-center"
                                                    title="@nextLabel"
                                                    aria-label="@nextLabel">
                                                <span class="material-symbols-rounded admin-icon-sm" aria-hidden="true">@nextIcon</span>
                                            </button>
                                        </form>
                                    }
                                    @if (OrderStatusHelper.CanCancel(item.Status))
                                    {
                                        <a asp-action="UpdateStatus" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger d-inline-flex align-items-center justify-content-center"
                                           title="Hủy đơn hàng"
                                           aria-label="Hủy đơn hàng mã số @item.Id">
                                            <span class="material-symbols-rounded admin-icon-sm" aria-hidden="true">cancel</span>
                                        </a>
                                    }
                                    @if (OrderStatusHelper.CanDelete(item.Status))
                                    {
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này? Chỉ nên xóa đơn tạo nhầm khi chưa xử lý.');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-sm btn-danger d-inline-flex align-items-center justify-content-center"
                                                    title="Xóa đơn tạo nhầm"
                                                    aria-label="Xóa đơn hàng mã số @item.Id">
                                                <span class="material-symbols-rounded admin-icon-sm" aria-hidden="true">delete</span>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Không tìm thấy đơn hàng nào khớp với bộ lọc.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="Model.Orders" />
</div>
