<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CMS Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;550;600;650;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..24,400,0,0&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin-theme.css" asp-appenđãversion="true" />
</head>
<body class="admin-shell">
    <header class="admin-topbar d-flex align-items-center justify-content-between px-3 px-lg-4 gap-3">
        <div class="admin-topbar-brand d-flex align-items-center gap-2">
            <span class="material-symbols-rounded" aria-hidden="true">admin_panel_settings</span>
            <span>CMS Admin</span>
        </div>
        <div class="admin-search-shell d-none đãmd-flex align-items-center justify-content-between">
            <span class="d-inline-flex align-items-center gap-2">
                <span class="material-symbols-rounded admin-icon-sm" aria-hidden="true">search</span>
                Tìm kiếm
            </span>
            <kbd>CTRL K</kbd>
        </div>
        <div class="ms-auto d-flex align-items-center gap-2 small">
            <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">Xem trang public</a>
            <span class="badge bg-success">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
        </div>
    </header>

    <div class="admin-layout">
            <!-- Sidebar -->
            <nav class="sidebar-panel p-0 d-flex flex-column justify-content-between">
                <div>
                    <div class="mt-2">
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
                           asp-controller="Home" asp-action="Dashboard">
                            <span class="material-symbols-rounded" aria-hidden="true">dashboard</span> Bảng điều khiển
                        </a>

                        <div class="nav-section">Nội dung</div>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
                           asp-controller="Category" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">folder</span> Quản lý Danh mục
                        </a>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Post" ? "active" : "")"
                           asp-controller="Post" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">article</span> Quản lý Bài viết
                        </a>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Banner" ? "active" : "")"
                           asp-controller="Banner" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">view_carousel</span> Quản lý Banner
                        </a>

                        <div class="nav-section">Sản phẩm</div>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "ProductCategory" ? "active" : "")"
                           asp-controller="ProductCategory" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">category</span> Danh mục sản phẩm
                        </a>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")"
                           asp-controller="Product" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">inventory_2</span> Sản phẩm
                        </a>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Stock" ? "active" : "")"
                           asp-controller="Stock" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">warehouse</span> Quản lý Tồn kho
                        </a>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "OptionGroup" ? "active" : "")"
                           asp-controller="OptionGroup" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">tune</span> Nhóm tùy chọn
                        </a>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "OptionValue" ? "active" : "")"
                           asp-controller="OptionValue" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">list_alt</span> Giá trị tùy chọn
                        </a>

                        <div class="nav-section">Bán hàng</div>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")"
                           asp-controller="Customer" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">groups</span> Khách hàng
                        </a>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "CustomerAddress" ? "active" : "")"
                           asp-controller="CustomerAddress" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">location_on</span> Địa chỉ khách hàng
                        </a>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Voucher" ? "active" : "")"
                           asp-controller="Voucher" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">sell</span> Voucher
                        </a>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")"
                           asp-controller="Order" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">shopping_cart</span> Đơn hàng
                        </a>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "OrderDetail" ? "active" : "")"
                           asp-controller="OrderDetail" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">receipt_long</span> Chi tiết đơn hàng
                        </a>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Review" ? "active" : "")"
                           asp-controller="Review" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">reviews</span> Đánh giá
                        </a>

                        <div class="nav-section">Hệ thống</div>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Store" ? "active" : "")"
                           asp-controller="Store" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">storefront</span> Cửa hàng
                        </a>
                        <a class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")"
                           asp-controller="User" asp-action="Index">
                            <span class="material-symbols-rounded" aria-hidden="true">manage_accounts</span> Quản lý Thành viên
                        </a>
                    </div>
                </div>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="sidebar-user-card mb-3">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="material-symbols-rounded fs-5" aria-hidden="true">account_circle</span>
                            <div>
                                <div class="fw-semibold small">@User.FindFirst("FullName")?.Value</div>
                                <span class="badge bg-light text-dark px-2 py-1" style="font-size: 0.65rem;">
                                    @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                </span>
                            </div>
                        </div>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-danger btn-sm w-100 text-center py-1 mt-2">
                            <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">logout</span> Đăng xuất
                        </a>
                    </div>
                }
            </nav>

            <!-- Main Content -->
            <div class="admin-main-area">
                <main class="admin-content">
                    @RenderBody()
                </main>
            </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
