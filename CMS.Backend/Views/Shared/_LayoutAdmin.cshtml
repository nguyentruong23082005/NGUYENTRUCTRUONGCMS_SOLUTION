<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CMS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { margin: 0; padding: 0; }
        .sidebar { min-height: 100vh; background-color: #212529; color: white; }
        .sidebar a { color: #adb5bd; text-decoration: none; display: block; padding: 10px 20px; }
        .sidebar a:hover { background-color: #343a40; color: white; }
        .sidebar .active { background-color: #0d6efd; color: white; }
        .sidebar .nav-section { font-size: 0.75rem; text-transform: uppercase; color: #6c757d; padding: 15px 20px 5px; letter-spacing: 0.05em; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 sidebar p-0">
                <div class="p-3 text-center border-bottom border-secondary">
                    <h4 class="text-white mb-0"><i class="bi bi-gear-fill"></i> CMS Admin</h4>
                </div>
                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Dashboard">
                        <i class="bi bi-speedometer2"></i> Bảng điều khiển
                    </a>

                    <div class="nav-section">Nội dung</div>
                    <a asp-controller="Category" asp-action="Index">
                        <i class="bi bi-folder"></i> Quản lý Danh mục
                    </a>
                    <a asp-controller="Post" asp-action="Index">
                        <i class="bi bi-file-earmark-post"></i> Quản lý Bài viết
                    </a>

                    <div class="nav-section">Sản phẩm</div>
                    <a asp-controller="ProductCategory" asp-action="Index">
                        <i class="bi bi-grid"></i> Danh mục sản phẩm
                    </a>
                    <a asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box-seam"></i> Sản phẩm
                    </a>

                    <div class="nav-section">Bán hàng</div>
                    <a asp-controller="Customer" asp-action="Index">
                        <i class="bi bi-person-lines-fill"></i> Khách hàng
                    </a>
                    <a asp-controller="Order" asp-action="Index">
                        <i class="bi bi-cart3"></i> Đơn hàng
                    </a>
                    <a asp-controller="OrderDetail" asp-action="Index">
                        <i class="bi bi-list-check"></i> Chi tiết đơn hàng
                    </a>

                    <div class="nav-section">Hệ thống</div>
                    <a asp-controller="User" asp-action="Index">
                        <i class="bi bi-people"></i> Quản lý Thành viên
                    </a>
                </div>

                @* Thông tin người dùng + nút Đăng xuất (Buổi 5) *@
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="p-3 border-top border-secondary mt-2">
                        <div class="text-muted small mb-1">
                            <i class="bi bi-person-circle"></i>
                            <strong class="text-white">@User.FindFirst("FullName")?.Value</strong>
                        </div>
                        <div class="text-muted" style="font-size:0.75rem;">
                            Quyền: <span class="badge bg-warning text-dark">
                                @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                            </span>
                        </div>
                        <a asp-controller="Account" asp-action="Logout"
                           class="btn btn-outline-danger btn-sm mt-2 w-100">
                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                        </a>
                    </div>
                }
            </nav>

            <main class="col-md-9 col-lg-10 ms-sm-auto p-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
