@model ErrorViewModel
@{
    ViewData["Title"] = "Đã xảy ra lỗi";
}

<div class="card-premium mx-auto" style="max-width: 820px;">
    <div class="d-flex align-items-start gap-3 mb-4">
        <span class="material-symbols-rounded text-danger" aria-hidden="true" style="font-size: 48px;">error</span>
        <div>
            <p class="text-uppercase fw-bold text-danger small mb-2">L?i hệ thống</p>
            <h1 class="h3 fw-bold mb-2">Đã xảy ra lỗi khi xử lý yêu cầu</h1>
            <p class="text-muted mb-0">Vui lòng thử lại sau hoặc liên hệ quản trị viên nếu sự cố tiếp tục xảy ra.</p>
        </div>
    </div>

    @if (Model.ShowRequestId)
    {
        <div class="alert border-0 rounded-3 mb-4" role="alert" style="background-color:#f8fafc;color:#334155;">
            <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">tag</span>
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </div>
    }

    <div class="p-3 rounded-3" style="background-color:#fff7ed;color:#9a3412;">
        <h2 class="h6 fw-bold mb-2">
            <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">developer_mode</span>
            Development Mode
        </h2>
        <p class="mb-2">
            Chuyển sang môi trường <strong>Development</strong> sẽ hiển thị thêm thông tin chi tiết về lỗi.
        </p>
        <p class="mb-0 small">
            Không bật Development trên môi trường production vì có thể làm lộ thông tin nhạy cảm từ exception.
        </p>
    </div>
</div>
