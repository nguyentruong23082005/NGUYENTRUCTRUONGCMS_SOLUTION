@model CMS.Backend.Models.PaginatedList<CMS.Data.Entities.User>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý thành viên";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold"><i class="bi bi-people-fill text-muted"></i> Quản lý Thành viên</h1>
        <a asp-action="Create" class="btn-premium-primary text-decoration-none">
            <i class="bi bi-plus-lg"></i> Thêm thành viên mới
        </a>
    </div>

    <div class="table-responsive">
        <table class="table-premium">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Tên đăng nhập</th>
                    <th scope="col">Họ và Tên</th>
                    <th scope="col">Vai trò</th>
                    <th scope="col" width="160">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Chưa có thành viên nào.</td>
                    </tr>
                }
                else
                {
                    foreach (var user in Model.Items)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td class="fw-semibold text-black">@user.Username</td>
                            <td>@user.FullName</td>
                            <td>
                                @if (user.Role == "Admin")
                                {
                                    <span class="badge bg-danger rounded-pill px-2.5 py-1">Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary rounded-pill px-2.5 py-1">Editor</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@user.Id" 
                                       class="btn btn-sm btn-warning" 
                                       aria-label="Sửa thông tin của @user.FullName">Sửa</a>
                                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" 
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa thành viên @user.Username không?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" 
                                                aria-label="Xóa thành viên @user.FullName">Xóa</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="Model" />
</div>
