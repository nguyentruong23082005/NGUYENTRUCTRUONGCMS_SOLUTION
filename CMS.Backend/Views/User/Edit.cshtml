@model CMS.Data.Entities.User

@{
    ViewData["Title"] = "Sửa thành viên";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="text-warning mb-4">✏️ Cập Nhật Thông Tin Thành Viên</h2>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Username" class="form-label fw-bold">Tên đăng nhập</label>
            <input asp-for="Username" class="form-control" readonly />
            <small class="text-muted">Tên đăng nhập không được phép sửa.</small>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Mật khẩu mới</label>
            <input type="password" name="newPassword" class="form-control"
                   placeholder="Để trống nếu không muốn đổi mật khẩu" />
        </div>

        <div class="mb-3">
            <label asp-for="FullName" class="form-label fw-bold">Họ và Tên</label>
            <input asp-for="FullName" class="form-control" required />
        </div>

        <div class="mb-3">
            <label asp-for="Role" class="form-label fw-bold">Vai trò</label>
            <select asp-for="Role" class="form-select">
                <option value="Admin">Quản trị viên (Admin)</option>
                <option value="Editor">Biên tập viên (Editor)</option>
            </select>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning">Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>
