@model CMS.Data.Entities.PostCategory

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa Danh mục";
}

<div class="card-premium">
    <div class="mb-4">
        <h1 class="h3 mb-1 fw-bold"><span class="material-symbols-rounded align-middle text-muted" aria-hidden="true">folder_managed</span> Chỉnh sửa Danh mục</h1>
        <p class="text-muted small">Cập nhật thông tin của danh mục bài viết.</p>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                <div class="mb-4">
                    <label asp-for="Name" class="form-label fw-semibold">Tên danh mục</label>
                    <input asp-for="Name" class="form-control" placeholder="Tên danh mục" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-semibold">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả danh mục..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="mt-4 pt-2">
                    <button type="submit" class="btn btn-premium-primary border-0 me-2">
                        <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">save</span>
                        Lưu thay đổi
                    </button>
                    <a asp-action="Index" class="btn btn-premium-outline text-decoration-none">
                        <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">arrow_back</span>
                        Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
