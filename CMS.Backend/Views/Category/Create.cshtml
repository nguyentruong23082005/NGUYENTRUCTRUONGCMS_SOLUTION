@model CMS.Data.Entities.Category

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm mới Danh mục";
}

<div class="card-premium">
    <div class="mb-4">
        <h1 class="h3 mb-1 fw-bold"><i class="bi bi-folder-plus text-muted"></i> Thêm mới Danh mục</h1>
        <p class="text-muted small">Tạo danh mục mới để phân loại các bài viết trong hệ thống.</p>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <form asp-action="Create">
                <div class="mb-4">
                    <label asp-for="Name" class="form-label">Tên danh mục</label>
                    <input asp-for="Name" class="form-control" placeholder="Ví dụ: Tin tức Sự kiện" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Description" class="form-label">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả cho danh mục..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="mt-4 pt-2">
                    <button type="submit" class="btn btn-premium-primary border-0 me-2">Lưu danh mục</button>
                    <a asp-action="Index" class="btn btn-premium-outline text-decoration-none">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>
