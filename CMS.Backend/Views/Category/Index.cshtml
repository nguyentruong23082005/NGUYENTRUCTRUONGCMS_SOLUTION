@model List<CMS.Data.Entities.Category>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Danh sách danh mục";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold"><i class="bi bi-folder-fill text-muted"></i> Danh sách Danh mục</h1>
        <a asp-action="Create" class="btn-premium-primary text-decoration-none">
            <i class="bi bi-plus-lg"></i> Thêm mới Danh mục
        </a>
    </div>

    <div class="table-responsive">
        <table class="table-premium">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Tên danh mục</th>
                    <th scope="col">Mô tả</th>
                    <th scope="col" width="160">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-semibold text-black">@item.Name</td>
                        <td class="text-muted">@item.Description</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" 
                                   class="btn btn-sm btn-warning" 
                                   aria-label="Sửa danh mục @item.Name">Sửa</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" 
                                      onsubmit="return confirm('Bạn có chắc chắn muốn xóa danh mục này?');">
                                    <button type="submit" class="btn btn-sm btn-danger" 
                                            aria-label="Xóa danh mục @item.Name">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>