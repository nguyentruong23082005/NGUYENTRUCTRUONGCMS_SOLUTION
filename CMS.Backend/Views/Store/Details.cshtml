@model CMS.Data.Entities.Store

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết cửa hàng";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold">
            <span class="material-symbols-rounded align-middle text-muted" aria-hidden="true">storefront</span>
            @Model.Name
        </h1>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-premium-primary border-0 text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">edit_square</span>
                Sửa
            </a>
            <a asp-action="Index" class="btn btn-premium-outline text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">arrow_back</span>
                Quay lại
            </a>
        </div>
    </div>

    <dl class="row mb-0">
        <dt class="col-sm-3 text-muted">Địa chỉ</dt>
        <dd class="col-sm-9 fw-semibold">@Model.Address</dd>

        <dt class="col-sm-3 text-muted">Điện thoại</dt>
        <dd class="col-sm-9">@(Model.Phone ?? "Chưa có")</dd>

        <dt class="col-sm-3 text-muted">Khu vực</dt>
        <dd class="col-sm-9">@Model.District, @Model.Province</dd>

        <dt class="col-sm-3 text-muted">Giờ hoạt động</dt>
        <dd class="col-sm-9">@Model.OpeningTime.ToString(@"hh\:mm") - @Model.ClosingTime.ToString(@"hh\:mm")</dd>

        <dt class="col-sm-3 text-muted">Mã quận/huyện GHN</dt>
        <dd class="col-sm-9">
            @if (Model.GhnDistrictId.HasValue)
            {
                <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1" style="font-weight: 600;">
                    @Model.GhnDistrictId
                </span>
            }
            else
            {
                <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1" style="font-weight: 600;">
                    Chưa đồng bộ (Tự động cập nhật khi xem danh sách cửa hàng)
                </span>
            }
        </dd>

        <dt class="col-sm-3 text-muted">Google Map</dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrWhiteSpace(Model.GoogleMapUrl))
            {
                <a href="@Model.GoogleMapUrl" target="_blank" rel="noopener" class="text-decoration-none">
                    <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">map</span>
                    Mở bản đồ
                </a>
            }
            else
            {
                <span class="text-muted">Chưa có</span>
            }
        </dd>

        <dt class="col-sm-3 text-muted">Tọa độ</dt>
        <dd class="col-sm-9">@Model.Latitude, @Model.Longitude</dd>
    </dl>
</div>
