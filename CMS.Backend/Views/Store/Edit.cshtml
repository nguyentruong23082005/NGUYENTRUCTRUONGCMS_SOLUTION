@model CMS.Data.Entities.Store
@{ Layout = "_LayoutAdmin"; ViewData["Title"] = "Sửa cửa hàng"; }
<div class="card-premium">
    <h1 class="h3 mb-4 fw-bold"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">edit_square</span> Sửa cửa hàng</h1>
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()<input type="hidden" asp-for="Id" /><div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="Name" class="form-label fw-semibold">Tên cửa hàng</label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="Phone" class="form-label fw-semibold">Số điện thoại</label><input asp-for="Phone" class="form-control" /></div>
            <div class="col-12"><label asp-for="Address" class="form-label fw-semibold">Địa chỉ</label><input asp-for="Address" class="form-control" /><span asp-validation-for="Address" class="text-danger"></span></div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Tỉnh/TP</label>
                <select id="sel-province" class="form-select">
                    <option value="">Chọn Tỉnh/Thành phố</option>
                </select>
                <input asp-for="Province" type="hidden" id="hid-province" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Quận/Huyện</label>
                <select id="sel-district" class="form-select" disabled>
                    <option value="">Chọn Quận/Huyện</option>
                </select>
                <input asp-for="District" type="hidden" id="hid-district" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Phường/Xã</label>
                <select id="sel-ward" class="form-select" disabled>
                    <option value="">Chọn Phường/Xã</option>
                </select>
                <input asp-for="Ward" type="hidden" id="hid-ward" />
            </div>
            <div class="col-md-6"><label asp-for="OpeningTime" class="form-label fw-semibold">Giờ mở cửa</label><input asp-for="OpeningTime" type="time" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="ClosingTime" class="form-label fw-semibold">Giờ đóng cửa</label><input asp-for="ClosingTime" type="time" class="form-control" /><span asp-validation-for="ClosingTime" class="text-danger"></span></div>
            <div class="col-12"><label asp-for="GoogleMapUrl" class="form-label fw-semibold">Google Map URL</label><input asp-for="GoogleMapUrl" class="form-control" /></div>
            <div class="col-12"><label asp-for="ImageUrl" class="form-label fw-semibold">Image URL</label><input asp-for="ImageUrl" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="Latitude" class="form-label fw-semibold">Latitude</label><input asp-for="Latitude" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="Longitude" class="form-label fw-semibold">Longitude</label><input asp-for="Longitude" class="form-control" /></div>
        </div>
        <div class="d-flex gap-2 mt-4"><button type="submit" class="btn btn-premium-primary border-0 me-2"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">save</span> Cập nhật</button><a asp-action="Index" class="btn btn-premium-outline text-decoration-none"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">arrow_back</span> Hủy</a></div>
    </form>
</div>

@section Scripts {
<script src="~/js/administrative-mapper.js"></script>
<script>
(function () {
    const API = 'https://provinces.open-api.vn/api';
    const selProvince = document.getElementById('sel-province');
    const selDistrict = document.getElementById('sel-district');
    const selWard     = document.getElementById('sel-ward');
    const hidProvince = document.getElementById('hid-province');
    const hidDistrict = document.getElementById('hid-district');
    const hidWard     = document.getElementById('hid-ward');

    const initialProvinceName = '@Html.Raw(Model.Province)';
    let initialDistrictName   = '@Html.Raw(Model.District)';
    let initialWardName       = '@Html.Raw(Model.Ward)';

    // Ánh xạ các đơn vị hành chính cũ trước sáp nhập sang đơn vị mới sau sáp nhập
    const mapped = mapOldAdministrativeNames(initialDistrictName, initialWardName);
    initialDistrictName = mapped.districtName;
    initialWardName     = mapped.wardName;

    async function populate(sel, items, placeholder) {
        sel.innerHTML = `<option value="">${placeholder}</option>`;
        items.forEach(i => {
            const opt = document.createElement('option');
            opt.value = i.code;
            opt.text  = i.name;
            sel.appendChild(opt);
        });
    }

    async function init() {
        // Load provinces
        const provinces = await fetch(`${API}/p/`).then(r => r.json());
        await populate(selProvince, provinces, 'Chọn Tỉnh/Thành phố');

        if (initialProvinceName) {
            const foundProv = provinces.find(p => p.name === initialProvinceName);
            if (foundProv) {
                selProvince.value = foundProv.code;
                hidProvince.value = foundProv.name;

                // Load districts
                const distData = await fetch(`${API}/p/${foundProv.code}?depth=2`).then(r => r.json());
                const districts = distData.districts || [];
                await populate(selDistrict, districts, 'Chọn Quận/Huyện');
                selDistrict.disabled = false;

                if (initialDistrictName) {
                    const foundDist = districts.find(d => d.name === initialDistrictName);
                    if (foundDist) {
                        selDistrict.value = foundDist.code;
                        hidDistrict.value = foundDist.name;

                        // Load wards
                        const wardData = await fetch(`${API}/d/${foundDist.code}?depth=2`).then(r => r.json());
                        const wards = wardData.wards || [];
                        await populate(selWard, wards, 'Chọn Phường/Xã');
                        selWard.disabled = false;

                        if (initialWardName) {
                            const foundWard = wards.find(w => w.name === initialWardName);
                            if (foundWard) {
                                selWard.value = foundWard.code;
                                hidWard.value = foundWard.name;
                            }
                        }
                    }
                }
            }
        }
    }

    init().catch(console.error);

    selProvince.addEventListener('change', async function () {
        hidProvince.value = this.options[this.selectedIndex]?.text || '';
        hidDistrict.value = ''; hidWard.value = '';
        selDistrict.innerHTML = '<option value="">Chọn Quận/Huyện</option>';
        selWard.innerHTML     = '<option value="">Chọn Phường/Xã</option>';
        selDistrict.disabled  = true; selWard.disabled = true;
        if (!this.value) return;
        const data = await fetch(`${API}/p/${this.value}?depth=2`).then(r => r.json());
        await populate(selDistrict, data.districts || [], 'Chọn Quận/Huyện');
        selDistrict.disabled = false;
    });

    selDistrict.addEventListener('change', async function () {
        hidDistrict.value = this.options[this.selectedIndex]?.text || '';
        hidWard.value = '';
        selWard.innerHTML = '<option value="">Chọn Phường/Xã</option>';
        selWard.disabled  = true;
        if (!this.value) return;
        const data = await fetch(`${API}/d/${this.value}?depth=2`).then(r => r.json());
        await populate(selWard, data.wards || [], 'Chọn Phường/Xã');
        selWard.disabled = false;
    });

    selWard.addEventListener('change', function () {
        hidWard.value = this.options[this.selectedIndex]?.text || '';
    });
}());
</script>
}
