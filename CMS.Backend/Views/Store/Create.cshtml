@model CMS.Data.Entities.Store
@{ Layout = "_LayoutAdmin"; ViewData["Title"] = "Thêm cửa hàng"; }
<div class="card-premium">
    <h1 class="h3 mb-4 fw-bold"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">add_business</span> Thêm cửa hàng</h1>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="Name" class="form-label fw-semibold">Tên cửa hàng</label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="Phone" class="form-label fw-semibold">Số điện thoại</label><input asp-for="Phone" class="form-control" /></div>
            <div class="col-12"><label asp-for="Address" class="form-label fw-semibold">Địa chỉ</label><input asp-for="Address" class="form-control" /><span asp-validation-for="Address" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="Province" class="form-label fw-semibold">Tỉnh/TP</label><input asp-for="Province" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="District" class="form-label fw-semibold">Quận/Huyện</label><input asp-for="District" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="OpeningTime" class="form-label fw-semibold">Giờ mở cửa</label><input asp-for="OpeningTime" type="time" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="ClosingTime" class="form-label fw-semibold">Giờ đóng cửa</label><input asp-for="ClosingTime" type="time" class="form-control" /><span asp-validation-for="ClosingTime" class="text-danger"></span></div>
            <div class="col-12"><label asp-for="GoogleMapUrl" class="form-label fw-semibold">Google Map URL</label><input asp-for="GoogleMapUrl" class="form-control" /></div>
            <div class="col-12"><label asp-for="ImageUrl" class="form-label fw-semibold">Image URL</label><input asp-for="ImageUrl" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="Latitude" class="form-label fw-semibold">Latitude</label><input asp-for="Latitude" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="Longitude" class="form-label fw-semibold">Longitude</label><input asp-for="Longitude" class="form-control" /></div>
        </div>
        <div class="d-flex gap-2 mt-4"><button type="submit" class="btn btn-premium-primary border-0 me-2"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">save</span> Lưu</button><a asp-action="Index" class="btn btn-premium-outline text-decoration-none"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">arrow_back</span> Hủy</a></div>
    </form>
</div>
