@model CMS.Data.Entities.Store
@{ Layout = "_LayoutAdmin"; ViewData["Title"] = "Thêm cửa hàng"; }
<div class="card-premium">
    <h1 class="h3 mb-4 fw-bold"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">add_business</span> Thêm cửa hàng</h1>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="Name" class="form-label fw-semibold">Tên cửa hàng</label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="Phone" class="form-label fw-semibold">Số điện thoại</label><input asp-for="Phone" class="form-control" /></div>
            <div class="col-12"><label asp-for="Address" class="form-label fw-semibold">Địa chỉ chi tiết</label><input asp-for="Address" class="form-control" /><span asp-validation-for="Address" class="text-danger"></span></div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">Tỉnh/TP</label>
                <select id="sel-province" class="form-select">
                    <option value="">Chọn Tỉnh/Thành phố</option>
                </select>
                <input asp-for="Province" type="hidden" id="hid-province" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Quận/Huyện</label>
                <select id="sel-district" class="form-select" disabled>
                    <option value="">Chọn Quận/Huyện</option>
                </select>
                <input asp-for="District" type="hidden" id="hid-district" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Phường/Xã</label>
                <select id="sel-ward" class="form-select" disabled>
                    <option value="">Chọn Phường/Xã</option>
                </select>
                <input asp-for="Ward" type="hidden" id="hid-ward" />
            </div>

            <div class="col-md-6"><label asp-for="OpeningTime" class="form-label fw-semibold">Giờ mở cửa</label><input asp-for="OpeningTime" type="time" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="ClosingTime" class="form-label fw-semibold">Giờ đóng cửa</label><input asp-for="ClosingTime" type="time" class="form-control" /><span asp-validation-for="ClosingTime" class="text-danger"></span></div>
            <div class="col-12"><label asp-for="GoogleMapUrl" class="form-label fw-semibold">Google Map URL</label><input asp-for="GoogleMapUrl" class="form-control" /></div>
            <div class="col-12"><label asp-for="ImageUrl" class="form-label fw-semibold">Image URL</label><input asp-for="ImageUrl" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="Latitude" class="form-label fw-semibold">Latitude</label><input asp-for="Latitude" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="Longitude" class="form-label fw-semibold">Longitude</label><input asp-for="Longitude" class="form-control" /></div>
        </div>
        <div class="d-flex gap-2 mt-4"><button type="submit" class="btn btn-premium-primary border-0 me-2"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">save</span> Lưu</button><a asp-action="Index" class="btn btn-premium-outline text-decoration-none"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">arrow_back</span> Hủy</a></div>
    </form>
</div>

@section Scripts {
<script>
(function () {
    const selProvince = document.getElementById('sel-province');
    const selDistrict = document.getElementById('sel-district');
    const selWard     = document.getElementById('sel-ward');
    const hidProvince = document.getElementById('hid-province');
    const hidDistrict = document.getElementById('hid-district');
    const hidWard     = document.getElementById('hid-ward');

    let districtsData = null;
    let wardsData = null;

    async function populate(sel, items, placeholder) {
        sel.innerHTML = `<option value="">${placeholder}</option>`;
        items.forEach(i => {
            const opt = document.createElement('option');
            opt.value = i.code;
            opt.text  = i.name;
            sel.appendChild(opt);
        });
    }

    // Load provinces from local static json
    fetch('/data/provinces.json')
        .then(r => r.json())
        .then(data => populate(selProvince, data, 'Chọn Tỉnh/Thành phố'));

    selProvince.addEventListener('change', async function () {
        hidProvince.value = this.options[this.selectedIndex]?.text || '';
        hidDistrict.value = ''; hidWard.value = '';
        selDistrict.innerHTML = '<option value="">Chọn Quận/Huyện</option>';
        selWard.innerHTML     = '<option value="">Chọn Phường/Xã</option>';
        selDistrict.disabled  = true; selWard.disabled = true;
        if (!this.value) return;

        if (!districtsData) {
            districtsData = await fetch('/data/districts.json').then(r => r.json());
        }
        const list = districtsData[this.value] || [];
        await populate(selDistrict, list, 'Chọn Quận/Huyện');
        selDistrict.disabled = false;
    });

    selDistrict.addEventListener('change', async function () {
        hidDistrict.value = this.options[this.selectedIndex]?.text || '';
        hidWard.value = '';
        selWard.innerHTML = '<option value="">Chọn Phường/Xã</option>';
        selWard.disabled  = true;
        if (!this.value) return;

        if (!wardsData) {
            wardsData = await fetch('/data/wards.json').then(r => r.json());
        }
        const list = wardsData[this.value] || [];
        await populate(selWard, list, 'Chọn Phường/Xã');
        selWard.disabled = false;
    });

    selWard.addEventListener('change', function () {
        hidWard.value = this.options[this.selectedIndex]?.text || '';
    });
}());
</script>
}

