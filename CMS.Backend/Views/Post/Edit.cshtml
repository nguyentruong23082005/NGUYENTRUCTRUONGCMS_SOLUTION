@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="card-premium">
    <div class="mb-4">
        <h1 class="h3 mb-1 fw-bold"><i class="bi bi-pencil-square text-muted"></i> Chỉnh sửa Bài viết</h1>
        <p class="text-muted small">Cập nhật nội dung, chuyên mục hoặc hình ảnh đại diện của bài viết.</p>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="row">
            <div class="col-md-8">
                <div class="mb-4">
                    <label asp-for="Title" class="form-label">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Content" class="form-label">Nội dung chi tiết</label>
                    <textarea asp-for="Content" class="form-control" rows="12" placeholder="Nội dung bài viết..."></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-4">
                    <label asp-for="CategoryId" class="form-label">Chuyên mục</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required>
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
                
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-4">
                        <label class="form-label">Ảnh đại diện hiện tại</label>
                        <div class="p-2 border rounded bg-light text-center">
                            <img src="@Model.ImageUrl" alt="Ảnh hiện tại" class="img-fluid rounded" style="max-height: 150px; object-fit: cover;" />
                        </div>
                    </div>
                }
                
                <div class="mb-4">
                    <label for="uploadImage" class="form-label">Thay đổi ảnh đại diện</label>
                    <input type="file" id="uploadImage" name="uploadImage" class="form-control" accept="image/*" />
                </div>
                <div class="mb-4">
                    <label asp-for="ImageUrl" class="form-label">Hoặc đường dẫn ảnh (URL)</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="CreatedDate" class="form-label">Ngày xuất bản</label>
                    <input asp-for="CreatedDate" type="date" class="form-control" required />
                    <span asp-validation-for="CreatedDate" class="text-danger small"></span>
                </div>
                
                <hr class="my-4" />
                
                <div class="mt-4 pt-2">
                    <button type="submit" class="btn btn-premium-primary border-0 w-100 mb-2 py-2">
                        <i class="bi bi-save"></i> Cập nhật bài viết
                    </button>
                    <a asp-action="Index" class="btn btn-premium-outline text-decoration-none w-100 text-center py-2">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#Content'))
            .catch(error => {
                console.error(error);
            });
    </script>
}
