@model List<CMS.Data.Entities.Post>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Danh sách bài viết";
    var categories = ViewBag.Categories as List<CMS.Data.Entities.Category>;
    int? selectedCategoryId = ViewBag.FilterCategoryId as int?;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-dark">DANH SÁCH BÀI VIẾT</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm bài viết mới
        </a>
    </div>

    <form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
        <div class="col-md-4">
            <label class="form-label fw-bold">Lọc theo danh mục</label>
            <select name="categoryId" class="form-select">
                <option value="">-- Tất cả danh mục --</option>
                @if (categories != null)
                {
                    foreach (var category in categories)
                    {
                        if (selectedCategoryId == category.Id)
                        {
                            <option value="@category.Id" selected>@category.Name</option>
                        }
                        else
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-outline-primary">Lọc</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Bỏ lọc</a>
        </div>
    </form>

    <hr />

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="alert alert-info text-center">Không có bài viết nào.</div>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 180px; object-fit: cover;">
                        }
                        <div class="card-body">
                            <span class="badge bg-info text-dark">@(item.Category?.Name ?? "N/A")</span>
                            <h5 class="card-title text-primary mt-2">@item.Title</h5>
                            <p class="card-text text-truncate">@item.Content</p>
                            <p class="text-muted small">Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")</p>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Xem</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Sửa</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa bài viết này?');" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Xóa</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>