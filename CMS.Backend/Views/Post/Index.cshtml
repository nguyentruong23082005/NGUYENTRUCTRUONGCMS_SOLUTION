@model CMS.Backend.Models.PaginatedList<CMS.Data.Entities.Post>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Danh sách bài viết";
    var categories = ViewBag.Categories as List<CMS.Data.Entities.Category>;
    int? selectedCategoryId = ViewBag.FilterCategoryId as int?;
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold"><i class="bi bi-file-earmark-post-fill text-muted"></i> Quản lý Bài viết</h1>
        <a asp-action="Create" class="btn-premium-primary text-decoration-none">
            <i class="bi bi-plus-lg"></i> Thêm bài viết mới
        </a>
    </div>

    <!-- Filter Form -->
    <form asp-action="Index" method="get" class="row g-3 align-items-end mb-4 bg-light p-3 rounded-3 border">
        <div class="col-md-4">
            <label for="categoryId" class="form-label">Lọc theo danh mục</label>
            <select id="categoryId" name="categoryId" class="form-select">
                <option value=""> Tất cả danh mục </option>
                @if (categories != null)
                {
                    foreach (var category in categories)
                    {
                        if (selectedCategoryId == category.Id)
                        {
                            <option value="@category.Id" selected>@category.Name</option>
                        }
                        else
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-premium-primary border-0">Lọc</button>
            <a asp-action="Index" class="btn btn-premium-outline text-decoration-none text-center">Bỏ lọc</a>
        </div>
    </form>

    <div class="row">
        @if (!Model.Items.Any())
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-4">Không có bài viết nào.</div>
            </div>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border border-light shadow-sm" style="border-radius: 12px; overflow: hidden;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 180px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-light text-muted d-flex align-items-center justify-content-center" style="height: 180px;">
                                <i class="bi bi-image fs-1 opacity-25"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column justify-content-between p-4">
                            <div>
                                <span class="badge bg-light text-dark rounded-pill px-2.5 py-1 mb-2">
                                    @(item.Category?.Name ?? "N/A")
                                </span>
                                <h5 class="card-title fw-bold text-black mb-2">@item.Title</h5>
                                <p class="card-text text-muted small text-truncate-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    @item.Content
                                </p>
                            </div>
                            <div class="mt-3">
                                <p class="text-muted small mb-3"><i class="bi bi-calendar3"></i> @item.CreatedDate.ToString("dd/MM/yyyy")</p>
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" 
                                       class="btn btn-sm btn-premium-outline text-decoration-none py-1" 
                                       aria-label="Xem chi tiết bài viết @item.Title">Xem</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" 
                                       class="btn btn-sm btn-warning py-1" 
                                       aria-label="Sửa bài viết @item.Title">Sửa</a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" 
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa bài viết này?');" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger py-1" 
                                                aria-label="Xóa bài viết @item.Title"><i class="bi bi-trash"></i> Xóa</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <partial name="_Pagination" model="Model" />
</div>