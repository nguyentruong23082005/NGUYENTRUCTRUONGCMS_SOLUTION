@model CMS.Backend.Models.PostIndexViewModel

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Danh sách bài viết";
}

<div class="card-premium">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold"><span class="material-symbols-rounded align-middle text-muted" aria-hidden="true">article</span> Quản lý Bài viết</h1>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Trash" class="btn btn-premium-outline text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">delete</span>
                Thùng rác
            </a>
            <a asp-action="Create" class="btn-premium-primary text-decoration-none">
                <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">add</span> Thêm bài viết mới
            </a>
        </div>
    </div>

    <!-- Filter Form -->
    <form asp-action="Index" method="get" class="filter-section mb-4">
        <div class="row g-3">
            <div class="col-md-5">
                <label class="form-label fw-semibold text-muted small">Tìm kiếm bài viết</label>
                <input type="text" name="Search" value="@Model.Filter.Search" class="form-control" placeholder="Nhập tiêu đề bài viết cần tìm..." />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold text-muted small">Lọc theo danh mục</label>
                <select name="CategoryId" asp-items="Model.Categories" class="form-select">
                    <option value="">Tất cả danh mục</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end gap-2">
                <button type="submit" class="btn-search-premium flex-grow-1">
                    <span class="material-symbols-rounded align-middle">search</span> Lọc
                </button>
                <a asp-action="Index" class="btn-reset-premium" title="Xóa bộ lọc">
                    <span class="material-symbols-rounded align-middle">restart_alt</span>
                </a>
            </div>
        </div>
    </form>

    @{
        var excerpts = ViewBag.PostExcerpts as Dictionary<int, string> ?? new Dictionary<int, string>();
    }

    <div class="row">
        @if (!Model.Posts.Items.Any())
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-4">Không tìm thấy bài viết nào khớp với bộ lọc.</div>
            </div>
        }
        else
        {
            foreach (var item in Model.Posts.Items)
            {
                var excerpt = excerpts.ContainsKey(item.Id) ? excerpts[item.Id] : "";
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border border-light shadow-sm" style="border-radius: 12px; overflow: hidden;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 180px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-light text-muted d-flex align-items-center justify-content-center" style="height: 180px;">
                                <span class="material-symbols-rounded fs-1 opacity-25" aria-hidden="true">image</span>
                            </div>
                        }
                        <div class="card-body d-flex flex-column justify-content-between p-4">
                            <div>
                                <span class="badge bg-light text-dark rounded-pill px-2.5 py-1 mb-2">
                                    @(item.PostCategory?.Name ?? "N/A")
                                </span>
                                <h5 class="card-title fw-bold text-black mb-2">@item.Title</h5>
                                <p class="card-text text-muted small text-truncate-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    @excerpt
                                </p>
                            </div>
                            <div class="mt-3">
                                <p class="text-muted small mb-3">
                                    <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">calendar_month</span> 
                                    @((item.PublishedAt ?? item.CreatedAt).ToString("dd/MM/yyyy"))
                                </p>
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" 
                                       class="btn btn-sm btn-premium-outline text-decoration-none py-1" 
                                       aria-label="Xem chi tiết bài viết @item.Title"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">visibility</span> Xem</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" 
                                       class="btn btn-sm btn-warning d-inline-flex align-items-center justify-content-center" 
                                       aria-label="Sửa bài viết @item.Title"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">edit_square</span></a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" 
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa bài viết này?');" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger d-inline-flex align-items-center justify-content-center" 
                                                aria-label="Xóa bài viết @item.Title"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">delete</span></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <partial name="_Pagination" model="Model.Posts" />
</div>