@model CMS.Data.Entities.Post

@{
    bool isAdmin = User.Identity != null && User.Identity.IsAuthenticated;
    Layout = isAdmin ? "_LayoutAdmin" : "_Layout";
    ViewData["Title"] = Model.Title;
}

@if (isAdmin)
{
    <div class="card-premium">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0 fw-bold"><span class="material-symbols-rounded align-middle text-muted" aria-hidden="true">article</span> Chi tiết bài viết (Quản trị)</h1>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning py-1.5"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">edit_square</span> Sửa bài viết</a>
                <a asp-action="Index" class="btn btn-premium-outline py-1.5 text-decoration-none">Quay lại danh sách</a>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                <span class="badge bg-light text-dark rounded-pill px-3 py-1.5 mb-3">
                    @(Model.PostCategory?.Name ?? "N/A")
                </span>
                <h2 class="fw-bold text-black mb-3">@Model.Title</h2>
                <p class="text-muted small mb-4"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">calendar_month</span> Ngày đăng: @((Model.PublishedAt ?? Model.CreatedAt).ToString("dd/MM/yyyy"))</p>
                <hr class="my-4" />
                <div class="post-content admin-article-content lh-lg text-secondary">
                    @Html.Raw(Model.Content)
                </div>
            </div>
            <div class="col-md-4">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded-3 border" style="max-height: 300px; width: 100%; object-fit: cover;" />
                }
            </div>
        </div>
    </div>
}
else
{
    <!-- Guest Public View -->
    <div class="container my-5" style="max-width: 800px;">
        <div class="text-center mb-5">
            <a href="/" class="text-decoration-none text-muted small"><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">arrow_back</span> Quay lại trang chủ</a>
            <h1 class="display-5 fw-bold text-black mt-3 mb-3">@Model.Title</h1>
            <div class="text-muted small">
                <span class="badge bg-light text-dark rounded-pill px-3 py-1.5 me-2">@(Model.PostCategory?.Name ?? "N/A")</span>
                <span><span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">calendar_month</span> Đăng ngày: @((Model.PublishedAt ?? Model.CreatedAt).ToString("dd/MM/yyyy"))</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="text-center mb-5">
                <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded-4 shadow-sm" style="max-height: 400px; width: 100%; object-fit: cover;" />
            </div>
        }

        <article class="post-content public-article-content lh-lg text-secondary" style="font-family: 'Inter', sans-serif; font-size: 1.1rem;">
            @Html.Raw(Model.Content)
        </article>
    </div>
}
