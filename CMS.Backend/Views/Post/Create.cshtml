@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm bài viết mới";
}

<div class="card-premium">
    <div class="mb-4">
        <h1 class="h3 mb-1 fw-bold"><i class="bi bi-file-earmark-plus text-muted"></i> Thêm Bài viết mới</h1>
        <p class="text-muted small">Tạo và xuất bản bài viết mới lên trang chủ hệ thống.</p>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="row">
            <div class="col-md-8">
                <div class="mb-4">
                    <label asp-for="Title" class="form-label">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề bài viết..." required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Content" class="form-label">Nội dung chi tiết</label>
                    <textarea asp-for="Content" class="form-control" rows="12" placeholder="Viết nội dung tại đây..."></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-4">
                    <label asp-for="CategoryId" class="form-label">Chuyên mục</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required>
                        <option value="">Chọn danh mục</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label for="uploadImage" class="form-label">Tải ảnh đại diện lên</label>
                    <input type="file" id="uploadImage" name="uploadImage" class="form-control" accept="image/*" />
                </div>
                <div class="mb-4">
                    <label asp-for="ImageUrl" class="form-label">Hoặc nhập liên kết ảnh (URL)</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="CreatedDate" class="form-label">Ngày xuất bản</label>
                    <input asp-for="CreatedDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                    <span asp-validation-for="CreatedDate" class="text-danger small"></span>
                </div>
                
                <hr class="my-4" />
                
                <div class="mt-4 pt-2">
                    <button type="submit" class="btn btn-premium-primary border-0 w-100 mb-2 py-2">
                        <i class="bi bi-cloud-arrow-up"></i> Lưu và Đăng bài
                    </button>
                    <a asp-action="Index" class="btn btn-premium-outline text-decoration-none w-100 text-center py-2">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#Content'))
            .catch(error => {
                console.error(error);
            });
    </script>
}
