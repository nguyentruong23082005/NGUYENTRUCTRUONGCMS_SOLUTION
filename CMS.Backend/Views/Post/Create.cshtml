@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm bài viết mới";
}

<div class="card-premium">
    <div class="mb-4">
        <h1 class="h3 mb-1 fw-bold"><span class="material-symbols-rounded align-middle text-muted" aria-hidden="true">post_add</span> Thêm Bài viết mới</h1>
        <p class="text-muted small">Tạo và xuất bản bài viết mới lên trang chủ hệ thống.</p>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="row">
            <div class="col-md-8">
                <div class="mb-4">
                    <label asp-for="Title" class="form-label fw-semibold">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề bài viết..." required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Content" class="form-label fw-semibold">Nội dung chi tiết</label>
                    <textarea asp-for="Content" class="form-control" rows="12" placeholder="Viết nội dung tại đây..."></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-4">
                    <label asp-for="PostCategoryId" class="form-label fw-semibold">Chuyên mục</label>
                    <select asp-for="PostCategoryId" class="form-select" asp-items="ViewBag.CategoryList" required>
                        <option value="">Chọn danh mục</option>
                    </select>
                    <span asp-validation-for="PostCategoryId" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label for="uploadImage" class="form-label fw-semibold">Tải ảnh đại diện lên</label>
                    <input type="file" id="uploadImage" name="uploadImage" class="form-control" accept="image/*" />
                </div>
                <div class="mb-4">
                    <label asp-for="ImageUrl" class="form-label fw-semibold">Hoặc nhập liên kết ảnh (URL)</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="CreatedAt" class="form-label fw-semibold">Ngày xuất bản</label>
                    <input asp-for="CreatedAt" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                    <span asp-validation-for="CreatedAt" class="text-danger small"></span>
                </div>
                
                <hr class="my-4" />
                
                <div class="mt-4 pt-2">
                    <button type="submit" class="btn btn-premium-primary border-0 w-100 mb-2 py-2">
                        <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">cloud_upload</span> Lưu và Đăng bài
                    </button>
                    <a asp-action="Index" class="btn btn-premium-outline text-decoration-none w-100 text-center py-2">
                        <span class="material-symbols-rounded admin-icon-sm align-middle" aria-hidden="true">arrow_back</span> Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        class UploadAdapter {
            constructor(loader) { this.loader = loader; }
            upload() {
                return this.loader.file.then(file => {
                    const formData = new FormData();
                    formData.append('upload', file);
                    return fetch('/api/upload/ckeditor', {
                        method: 'POST',
                        body: formData,
                        credentials: 'same-origin'
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (!data.uploaded) throw new Error(data.error?.message || 'Upload thất bại');
                        return { default: data.url };
                    });
                });
            }
        }
        function UploadPlugin(editor) {
            editor.plugins.get('FileRepository').createUploadAdapter = (loader) => new UploadAdapter(loader);
        }
        ClassicEditor
            .create(document.querySelector('#Content'), {
                extraPlugins: [UploadPlugin]
            })
            .catch(error => {
                console.error(error);
            });
    </script>
}
