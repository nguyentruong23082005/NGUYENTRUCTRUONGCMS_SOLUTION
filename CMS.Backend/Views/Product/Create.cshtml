@model CMS.Data.Entities.Product

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="text-success mb-4">✨ Thêm Sản Phẩm Mới</h2>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm</label>
            <input asp-for="Name" class="form-control" required />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CategoryProductId" class="form-label fw-bold">Danh mục</label>
            <select asp-for="CategoryProductId" class="form-select" asp-items="ViewBag.CategoryProductId">
                <option value="">-- Chọn danh mục --</option>
            </select>
            <span asp-validation-for="CategoryProductId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Price" class="form-label fw-bold">Giá</label>
            <input asp-for="Price" type="number" step="0.01" class="form-control" required />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="StockQuantity" class="form-label fw-bold">Tồn kho</label>
            <input asp-for="StockQuantity" type="number" class="form-control" required />
            <span asp-validation-for="StockQuantity" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ImageUrl" class="form-label fw-bold">Đường dẫn ảnh (URL)</label>
            <input asp-for="ImageUrl" class="form-control" />
            <span asp-validation-for="ImageUrl" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Lưu vào hệ thống</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
