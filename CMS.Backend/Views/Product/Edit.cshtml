@model CMS.Data.Entities.Product

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Sửa sản phẩm";
}

<div class="card-premium">
    <div class="mb-4">
        <h1 class="h3 mb-1 fw-bold"><i class="bi bi-pencil-square text-muted"></i> Chỉnh sửa sản phẩm</h1>
        <p class="text-muted small">Cập nhật thông tin chi tiết của sản phẩm.</p>
    </div>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="row mb-4">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label">Tên sản phẩm</label>
                <input asp-for="Name" class="form-control" placeholder="Tên sản phẩm" required />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="CategoryProductId" class="form-label">Danh mục</label>
                <select asp-for="CategoryProductId" class="form-select" asp-items="ViewBag.CategoryProductId" required>
                    <option value="">-- Chọn danh mục --</option>
                </select>
                <span asp-validation-for="CategoryProductId" class="text-danger small"></span>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-6">
                <label asp-for="Price" class="form-label">Giá bán (VNĐ)</label>
                <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Giá bán" required />
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="StockQuantity" class="form-label">Số lượng tồn kho</label>
                <input asp-for="StockQuantity" type="number" class="form-control" placeholder="Tồn kho" required />
                <span asp-validation-for="StockQuantity" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-4">
            <label asp-for="ImageUrl" class="form-label">Đường dẫn ảnh sản phẩm (URL)</label>
            <input asp-for="ImageUrl" class="form-control" placeholder="http://example.com/image.jpg" />
            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Description" class="form-label">Mô tả sản phẩm</label>
            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả sản phẩm..."></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <div class="mt-4 pt-2">
            <button type="submit" class="btn btn-premium-primary border-0 me-2">Cập nhật sản phẩm</button>
            <a asp-action="Index" class="btn btn-premium-outline text-decoration-none">Hủy bỏ</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
